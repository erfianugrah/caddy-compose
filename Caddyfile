{
	# Admin API — localhost for healthcheck/metrics + Unix socket for wafctl reload
	admin localhost:2019

	# Prometheus metrics — exposed via admin API at localhost:2019/metrics
	metrics

	email {$EMAIL}
	acme_dns cloudflare {$CF_API_TOKEN}
	cert_issuer acme
	grace_period 5s

	# Encrypted Client Hello — hides real SNI from ISP/eavesdroppers
	# Requires client DoH/DoT for full privacy benefit
	dns cloudflare {$CF_API_TOKEN}
	ech ech.erfi.io

	# Policy engine handles all WAF processing (allow/block/detect/rate_limit).
	# Caddy's order directive controls handler execution order globally —
	# textual position in site blocks is irrelevant.
	# log_append must run before policy_engine so that its middleware wraps the
	# policy engine handler chain. This ensures log fields (policy_action,
	# detect_rules, request_headers, etc.) are captured even when policy_engine
	# blocks the request (returning an error that short-circuits the chain).
	# Placeholders like {http.vars.policy_engine.action} are resolved lazily at
	# log-write time, so they pick up vars set by policy_engine downstream.
	order log_append first
	order policy_engine after log_append

	log {
		level INFO
		output file /var/log/access.log {
			roll_size 128mb
			roll_keep 3
			roll_keep_for 168h
		}
		format json {
			time_format wall
		}
	}
	servers {
		strict_sni_host on
		protocols h1 h2 h3
		trusted_proxies_strict
		import /data/waf/cf_trusted_proxies.caddy
	}
	dynamic_dns {
		provider cloudflare {$CF_API_TOKEN}
		domains {
			erfi.io authelia caddy waf servarr navidrome vault immich caddy-prometheus jellyfin sabnzbd radarr bazarr prowlarr sonarr tracearr joplin keycloak qbit change seerr copyparty dockge httpbun httpbin cdn atuin
		}
		versions ipv4
		check_interval 5m
		ip_source upnp
		ip_source simple_http https://icanhazip.com
		ip_source simple_http https://api.ipify.org
		ip_source simple_http https://myip.addr.space
		ip_source simple_http https://ifconfig.me
		ip_source simple_http https://ident.me
		ip_source simple_http https://bot.whatismyipaddress.com
		ip_source simple_http https://ipecho.net/plain
	}
}

# WAF — policy engine as sole WAF (CRS rules baked into default-rules.json).
# CORS and static-asset caching are now managed by the policy engine plugin:
#   CORS         → /api/cors (preflight + origin validation)
#   Cache headers → /api/rules/templates/cache-static-assets/apply
# (waf)     — Unified WAF snippet. Per-service settings (paranoia level,
#             thresholds, mode) are managed via the wafctl Settings page.
#             WebSocket upgrade requests ARE inspected — the policy engine
#             implements http.Hijacker (v0.12.6+) so WS connections pass
#             through safely after the upgrade request is evaluated.
# (waf_off) — No WAF processing. For metrics-only or respond-only services.
(waf) {
	# Inject Caddy-generated request UUID for all requests (including WebSocket)
	# so it appears in access logs for cross-log correlation.
	request_header X-Request-Id {http.request.uuid}
	# Policy engine evaluates all WAF rules: allow/block/honeypot,
	# CRS detection (anomaly scoring), rate limiting.
	# Rules are hot-reloaded from JSON files written by wafctl.
	# WebSocket upgrade requests are scored normally — the plugin's
	# responseHeaderWriter implements http.Hijacker so the WS upgrade
	# succeeds after evaluation (plugin v0.12.6+).
	policy_engine {
		rules_file /data/waf/policy-rules.json
		default_rules_file /etc/caddy/waf/default-rules.json
		reload_interval 5s
	}
	handle_errors 400 403 429 {
		root * /etc/caddy/errors
		templates
		rewrite * /error.html
		file_server
	}
}

(waf_off) {
	# No WAF processing — placeholder snippet for services that don't need it.
}

# Common TLS config snippet
(tls_config) {
	tls {
		issuer acme {
			dns cloudflare {$CF_API_TOKEN}
			propagation_delay 60s
			propagation_timeout -1
			resolvers 1.1.1.1
		}
	}
}

# Standard log config — INFO level, per-site log file + combined log
# log_append adds custom fields to every access log entry:
# - request_id: Caddy UUID for cross-log correlation
# - policy_action: policy engine decision (allow/block/honeypot/detect_block, empty if no rule matched)
# - policy_rule: name of the matched rule, or detect block summary
# - policy_tags: comma-separated tags from matched rule(s)
# - policy_score: anomaly score (detect rules only, empty if no detect rules fired)
# - policy_detect_rules: matched detect rule details "id:severity:score,..." (detect_block only)
# - policy_detect_matches: JSON array of per-rule match details with field/var_name/value/matched_data
# - policy_request_headers: JSON-serialized request headers (only set on block/detect_block events)
# - policy_request_body: truncated request body excerpt (only set on block/detect_block when body was read)
(site_log) {
	log_append request_id {http.request.uuid}
	log_append policy_action {http.vars.policy_engine.action}
	log_append policy_rule {http.vars.policy_engine.rule_name}
	log_append policy_tags {http.vars.policy_engine.tags}
	log_append policy_score {http.vars.policy_engine.anomaly_score}
	log_append policy_detect_rules {http.vars.policy_engine.detect_rules}
	log_append policy_detect_matches {http.vars.policy_engine.detect_matches}
	log_append policy_request_headers {http.vars.policy_engine.request_headers}
	log_append policy_request_body {http.vars.policy_engine.request_body}
	log {
		level INFO
		output file /var/log/{args[0]}-access.log {
			roll_size 128mb
			roll_keep 3
			roll_keep_for 168h
		}
		format json {
			time_format wall
		}
	}
	log combined {
		level INFO
		output file /var/log/combined-access.log {
			mode 0644
			roll_size 256mb
			roll_keep 2
			roll_keep_for 168h
		}
		format json {
			time_format wall
		}
	}
}

# Authelia forward auth — applied to protected services
# Usage: import forward_auth
(forward_auth) {
	forward_auth 172.19.99.2:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Email Remote-Name
	}
}

# Common reverse proxy headers snippet
(proxy_headers) {
	trusted_proxies private_ranges
	header_up X-Forwarded-For {client_ip}
}

# Custom error pages — serves /etc/caddy/errors/error.html with Caddy templates
# Covers remaining error codes not handled by the (waf) snippet.
# The (waf) snippet handles 403 and 429 specifically; this catches the rest
# (404, 500, 502, 503, 504, etc.)
# Usage: import error_pages
(error_pages) {
	handle_errors {
		root * /etc/caddy/errors
		templates
		rewrite * /error.html
		file_server
	}
}

# caddy.erfi.io — Admin API is localhost-only.
# Use `docker exec caddy caddy reload --config /etc/caddy/Caddyfile` to reload.
# Or SSH tunnel: ssh -L 2019:localhost:2019 user@host
caddy.erfi.io {

	import tls_config
	encode zstd gzip
	respond "Caddy is running. Admin API available via localhost:2019 only." 200
	import error_pages
	import site_log caddy-api
}

waf.erfi.io {
	import forward_auth

	import tls_config
	encode zstd gzip
	# Hashed assets are immutable — only reached after forward_auth succeeds
	@waf_hashed path /_astro/*
	header @waf_hashed Cache-Control "public, max-age=31536000, immutable"
	# Fallback: auth redirects and HTML get no-store (prevents Cloudflare/browser caching 302s)
	header ?Cache-Control "no-store"
	# All requests (API + dashboard UI) go to wafctl sidecar.
	# wafctl serves API on /api/* and dashboard static files on all other paths.
	reverse_proxy 172.19.98.2:8080 {
		import proxy_headers
	}
	import error_pages
	import site_log waf
}

