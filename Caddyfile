git.erfi.io {
	import waf
	import tls_config
	encode zstd gzip
	reverse_proxy 172.40.0.2:3000 {
		import proxy_headers
		# Git HTTP operations (clone/push/pull) and LFS uploads can be
		# long-running with large payloads. Disable response timeout and
		# stream unbuffered for Actions SSE / LFS chunked transfers.
		flush_interval -1
		transport http {
			dial_timeout 5s
			response_header_timeout 0
		}
	}
	import error_pages
	import site_log gitea
}

