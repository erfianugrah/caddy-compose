{
	# Admin API - localhost for healthcheck/metrics + reload
	admin localhost:2019

	# Prometheus metrics - exposed via admin API at localhost:2019/metrics
	metrics

	email {$EMAIL}
	acme_dns cloudflare {$CF_API_TOKEN}
	cert_issuer acme
	grace_period 5s

	# WAF removed 2026-07-24: L7 policy_engine + L4 ddos_mitigator/ja4 listener
	# wrappers + cf_trusted_proxies import all dropped. servarr caddy is now a
	# plain TLS-terminating routing hop behind the MS-01 edge; the edge owns
	# L4 ddos and (per-service, as they migrate) L7 WAF.
	servers {
		strict_sni_host on
		protocols h1 h2 h3
		trusted_proxies_strict
		timeouts {
			idle 30s
		}
	}

	# L4 TCP proxy - git-over-SSH passthrough to Gitea (no TLS, SSH does its
	# own crypto). The docs-ssh :2222 forwarder was dropped (docs-ssh moved to
	# the MS-01 edge 2026-07-22).
	layer4 {
		# gitea-ssh: git.erfi.io:2223 -> 172.40.0.2:2222
		:2223 {
			@ssh ssh
			route @ssh {
				proxy 172.40.0.2:2222
			}
		}
	}
}

# Common TLS config snippet — used by sites under zones still served by
# Cloudflare DNS (erfi.dev, erfianugrah.com, etc.). ACME DNS-01 challenge
# TXT records get written to CF via their API.
(tls_config) {
	tls {
		issuer acme {
			dns cloudflare {$CF_API_TOKEN}
			propagation_delay 60s
			propagation_timeout -1
			resolvers 1.1.1.1
		}
	}
}

# TLS config for sites under zones served by our own Knot DNS on Fly.
# Currently: erfi.io (migrated 2026-05-24, lab.erfi.io subzone).
# Challenge TXT records get written to Knot via TSIG-authed nsupdate.
# See ~/knot-fly/ and ~/knot-fly/docs/runbooks/cf-to-knot-migration.md
# §Post-migration for the design.
(tls_config_rfc2136) {
	tls {
		issuer acme {
			dns rfc2136 {
				key_name "caddy-acme."
				key_alg "hmac-sha256"
				key {$TSIG_CADDY_ACME}
				server "137.66.1.170:53"
			}
			propagation_delay 30s
			resolvers 137.66.1.170
		}
	}
}

# Common reverse proxy headers snippet
(proxy_headers) {
	trusted_proxies private_ranges
	header_up X-Forwarded-For {client_ip}
}

# Custom error pages — serves /etc/caddy/errors/error.html with Caddy templates
# Covers remaining error codes not handled by the (waf) snippet.
# The (waf) snippet handles 403 and 429 specifically; this catches the rest
# (404, 500, 502, 503, 504, etc.)
# Usage: import error_pages
(error_pages) {
	handle_errors {
		root * /etc/caddy/errors
		templates
		rewrite * /error.html
		file_server
	}
}

# docs.erfi.io — Landing page for the SSH docs server.
# Static HTML served by busybox httpd inside the docs-ssh container.
docs.erfi.io {
	import tls_config_rfc2136
	encode zstd gzip
	# docs-ssh moved to the MS-01 edge (2026-07-22). Proxy to the edge caddy
	# over HTTPS until cutover. header_up Host is REQUIRED - the edge caddy
	# (strict_sni_host) 421s when caddy rewrites Host to the upstream address.
	reverse_proxy https://10.68.69.19 {
		import proxy_headers
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		transport http {
			tls_server_name docs.erfi.io
		}
	}
	import error_pages
}

# caddy.erfi.io — Admin API is localhost-only.
# Use `docker exec caddy caddy reload --config /etc/caddy/Caddyfile` to reload.
# Or SSH tunnel: ssh -L 2019:localhost:2019 user@host
