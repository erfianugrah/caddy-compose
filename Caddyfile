cdn.erfi.io {
	import tls_config_rfc2136
	encode zstd gzip

	# S3 API / bucket proxy - bucket policies control access.
	# Console - direct proxy (Authelia gate nuked 2026-07-23; MinIO's own
	# login is the gate). strip /console prefix for port 9001.
	route {
		@s3_api not path /console /console/*
		reverse_proxy @s3_api 172.70.0.2:9000 {
			import proxy_headers
		}

		uri strip_prefix /console
		reverse_proxy 172.70.0.2:9001 {
			import proxy_headers
		}
	}
	import error_pages
}

erfianugrah.com {
	# erfianugrah.com is still on CF DNS (only erfi.io migrated to Knot 2026-05-24).
	import tls_config
	encode zstd gzip
	# Astro hashed assets are immutable — cache for 1 year
	@hashed path /_astro/*
	header @hashed Cache-Control "public, max-age=31536000, immutable"
	# HTML pages — revalidate on every request
	header ?Cache-Control "public, max-age=0, must-revalidate"
	reverse_proxy 172.19.23.2:80 {
		import proxy_headers
	}
	import error_pages
}

# draw.erfi.io — Self-hosted Excalidraw (busybox httpd + 3 backends).
# Encryption keys live in URL fragments (#) — never sent to server.
# Referrer-Policy prevents leaking them to third parties.
# Ports bound to 127.0.0.1 — only reachable via this proxy.
draw.erfi.io {
	import tls_config_rfc2136
	encode zstd gzip

	# Security headers
	header Referrer-Policy "strict-origin-when-cross-origin"
	header X-Frame-Options "SAMEORIGIN"
	header X-Content-Type-Options "nosniff"
	header Permissions-Policy "camera=(), microphone=(), geolocation=()"
	header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' wss://draw.erfi.io; img-src 'self' data: blob:; font-src 'self' data:; frame-src 'self' blob:; worker-src 'self' blob:; child-src 'self' blob:"

	# CORS preflight - browsers never send cookies with OPTIONS,
	# so this must be handled early.
	@api_options {
		method OPTIONS
		path /api/*
	}
	handle @api_options {
		header Access-Control-Allow-Origin "https://draw.erfi.io"
		header Access-Control-Allow-Methods "GET, POST, PUT, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, X-API-Key"
		header Access-Control-Allow-Credentials "true"
		header Access-Control-Max-Age "86400"
		respond 204
	}

	# AI API — must match before the broader /api/* handler
	handle_path /api/ai/* {
		header Access-Control-Allow-Origin "https://draw.erfi.io"
		header Access-Control-Allow-Credentials "true"
		header Access-Control-Expose-Headers "X-Ratelimit-Limit, X-Ratelimit-Remaining"
		reverse_proxy localhost:3004 {
			import proxy_headers
		}
	}

	# Storage API
	handle_path /api/* {
		header Access-Control-Allow-Origin "https://draw.erfi.io"
		header Access-Control-Allow-Credentials "true"
		reverse_proxy localhost:3003 {
			import proxy_headers
		}
	}

	# Socket.io collaboration (WebSocket + long-polling)
	handle /socket.io/* {
		reverse_proxy localhost:3002 {
			import proxy_headers
			flush_interval -1
			# Grace period on config reload — avoids thundering herd of reconnects
			stream_close_delay 5m
			transport http {
				dial_timeout 5s
				response_header_timeout 0
			}
		}
	}

	# Static frontend (busybox httpd)
	handle {
		# Hashed assets — immutable, cache 1 year
		@hashed path /assets/*
		header @hashed Cache-Control "public, max-age=31536000, immutable"

		# HTML + service worker — never cache
		@nocache {
			path / /index.html /sw.js /workbox-*.js /registerSW.js
		}
		header @nocache Cache-Control "no-cache, no-store, must-revalidate"

		reverse_proxy localhost:3001 {
			import proxy_headers
		}
	}

	import error_pages
}

# ─── research stack ────────────────────────────────────────────────────────
