---
import "../styles/globals.css";

interface Props {
  title?: string;
  active?: string;
}

const { title = "wafctl", active = "overview" } = Astro.props;

const navLinks = [
  { id: "overview", label: "Overview", href: "/", icon: "grid", section: "" },
  { id: "events", label: "Security Events", href: "/events", icon: "list", section: "Observability" },
  { id: "logs", label: "Logs", href: "/logs", icon: "file-text", section: "Observability" },
  { id: "investigate", label: "IP Lookup", href: "/analytics", icon: "search", section: "Observability" },
  { id: "services", label: "Services", href: "/services", icon: "server", section: "Infrastructure" },
  // DDoS Protection: adaptive mitigation + IP jail
  { id: "dos", label: "DDoS Protection", href: "/dos", icon: "shield-alert", section: "Security" },
  // Policy: rules + rate limits + response headers + templates
  { id: "policy", label: "Policy Engine", href: "/policy", icon: "shield", section: "Security" },
  // CRS default rules + WAF engine settings
  { id: "rules", label: "WAF Settings", href: "/rules", icon: "book-open", section: "Security" },
  { id: "lists", label: "Managed Lists", href: "/lists", icon: "list-tree", section: "Security" },
  // Response header config (structured wizards)
  { id: "csp", label: "CSP", href: "/csp", icon: "lock", section: "Settings" },
  { id: "headers", label: "Security Headers", href: "/headers", icon: "file-check", section: "Settings" },
  { id: "cors", label: "CORS", href: "/cors", icon: "globe", section: "Settings" },
];

// Group nav links by section for collapsible rendering
const standaloneLinks = navLinks.filter((l) => !l.section);
const sectionOrder: string[] = [];
const sectionMap = new Map<string, typeof navLinks>();
for (const link of navLinks) {
  if (!link.section) continue;
  if (!sectionMap.has(link.section)) {
    sectionOrder.push(link.section);
    sectionMap.set(link.section, []);
  }
  sectionMap.get(link.section)!.push(link);
}
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  </head>
  <body class="h-screen overflow-hidden bg-background text-foreground antialiased">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside
        id="sidebar"
        class="hidden w-60 flex-shrink-0 border-r border-border bg-lovelace-950 md:block"
      >
        <div class="flex h-full flex-col">
          <!-- Logo area -->
          <div class="flex h-14 items-center gap-2 border-b border-border px-4">
            <div class="flex h-8 w-8 items-center justify-center rounded-md bg-lv-purple/10">
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
              >
                <path class="text-lv-purple" d="M12 2 L3 6.5 L3 12 C3 18.5 6.8 23 12 24.5 C17.2 23 21 18.5 21 12 L21 6.5 Z" stroke="currentColor" />
                <circle cx="12" cy="11" r="2.5" fill="currentColor" class="text-lv-purple" />
                <rect x="11" y="13" width="2" height="4" rx="0.8" fill="currentColor" class="text-lv-purple" />
              </svg>
            </div>
            <span
              class="text-sm font-bold tracking-wider text-lv-purple glow-purple"
            >
               WAFCTL
            </span>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 overflow-y-auto space-y-1 px-2 py-4">
            {/* Standalone links (no section) */}
            {standaloneLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors",
                  active === link.id
                    ? "bg-lv-purple/10 text-lv-purple"
                    : "text-muted-foreground hover:bg-accent hover:text-foreground",
                ]}
              >
                {link.icon === "grid" && (
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" />
                    <rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" />
                  </svg>
                )}
                <span>{link.label}</span>
              </a>
            ))}

            {/* Collapsible sections */}
            {sectionOrder.map((section) => {
              const links = sectionMap.get(section)!;
              const hasActive = links.some((l) => l.id === active);
              return (
                <div class="nav-section" data-section={section}>
                  <button
                    class="nav-section-toggle flex w-full items-center gap-1.5 px-3 pt-4 pb-1 group"
                    type="button"
                    data-section={section}
                  >
                    <svg
                      class="nav-chevron h-3 w-3 text-muted-foreground/60 transition-transform"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                    <span class="text-[10px] font-semibold uppercase tracking-widest text-muted-foreground/60 group-hover:text-muted-foreground transition-colors">
                      {section}
                    </span>
                  </button>
                  <div class="nav-section-links" data-section={section} data-has-active={hasActive ? "true" : "false"}>
                    {links.map((link) => (
                      <a
                        href={link.href}
                        class:list={[
                          "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors",
                          active === link.id
                            ? "bg-lv-purple/10 text-lv-purple"
                            : "text-muted-foreground hover:bg-accent hover:text-foreground",
                        ]}
                      >
                        {/* Search / Investigate */}
                        {link.icon === "search" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                          </svg>
                        )}
                        {/* Server / Services */}
                        {link.icon === "server" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="2" y="2" width="20" height="8" rx="2" ry="2" />
                            <rect x="2" y="14" width="20" height="8" rx="2" ry="2" />
                            <line x1="6" y1="6" x2="6.01" y2="6" />
                            <line x1="6" y1="18" x2="6.01" y2="18" />
                          </svg>
                        )}
                        {/* List / Events */}
                        {link.icon === "list" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" />
                            <line x1="8" y1="18" x2="21" y2="18" /><line x1="3" y1="6" x2="3.01" y2="6" />
                            <line x1="3" y1="12" x2="3.01" y2="12" /><line x1="3" y1="18" x2="3.01" y2="18" />
                          </svg>
                        )}
                        {/* File-text / Logs */}
                        {link.icon === "file-text" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                            <line x1="16" y1="13" x2="8" y2="13" />
                            <line x1="16" y1="17" x2="8" y2="17" />
                            <polyline points="10 9 9 9 8 9" />
                          </svg>
                        )}
                        {/* Book-open / Rules */}
                        {link.icon === "book-open" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                          </svg>
                        )}
                        {/* Shield / Policy */}
                        {link.icon === "shield-alert" && (
                           <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                             <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                             <path d="M12 8v4" /><path d="M12 16h.01" />
                           </svg>
                         )}
                         {link.icon === "shield" && (
                           <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                             <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                           </svg>
                         )}
                        {/* List Tree / Managed Lists */}
                        {link.icon === "list-tree" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" />
                            <line x1="8" y1="18" x2="21" y2="18" /><line x1="3" y1="6" x2="3.01" y2="6" />
                            <line x1="3" y1="12" x2="3.01" y2="12" /><line x1="3" y1="18" x2="3.01" y2="18" />
                          </svg>
                        )}
                        {/* Gauge / Rate Limits */}
                        {link.icon === "gauge" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 16v-4" /><path d="M12 8h.01" />
                            <circle cx="12" cy="12" r="10" />
                            <path d="m4.93 4.93 4.24 4.24" /><path d="m14.83 9.17 4.24-4.24" />
                          </svg>
                        )}
                        {/* File-check / Security Headers */}
                        {link.icon === "file-check" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                            <path d="m9 15 2 2 4-4" />
                          </svg>
                        )}
                        {/* Lock / CSP */}
                        {link.icon === "lock" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                          </svg>
                        )}
                        {/* Globe / CORS */}
                        {link.icon === "globe" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="2" y1="12" x2="22" y2="12" />
                            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                          </svg>
                        )}
                        {/* Layout-template / Templates */}
                        {link.icon === "layout-template" && (
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="7" rx="1" />
                            <rect x="3" y="14" width="9" height="7" rx="1" />
                            <rect x="16" y="14" width="5" height="7" rx="1" />
                          </svg>
                        )}

                        <span>{link.label}</span>
                      </a>
                    ))}
                  </div>
                </div>
              );
            })}
          </nav>

          <!-- Footer -->
          <div class="border-t border-border px-4 py-3">
            <div class="text-xs text-muted-foreground" id="sidebar-version">Policy Engine WAF</div>
          </div>
          <script>
            // Version display is updated by the shared health check below.
          </script>
        </div>
      </aside>

      <!-- Main content area -->
      <div class="flex flex-1 flex-col overflow-hidden">
        <!-- Header -->
        <header
          class="flex h-14 items-center justify-between border-b border-border bg-lovelace-950/50 px-6"
        >
          <!-- Mobile menu button -->
          <button
            class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent md:hidden"
            aria-label="Toggle menu"
            id="mobile-menu-btn"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>

          <h1 class="text-sm font-medium text-foreground">
            {title}
          </h1>

          <div class="flex items-center gap-3">
            <!-- Status indicator -->
            <div id="health-indicator" class="flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span
                  id="health-ping"
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-muted-foreground opacity-75"
                ></span>
                <span
                  id="health-dot"
                  class="relative inline-flex h-2 w-2 rounded-full bg-muted-foreground"
                ></span>
              </span>
              <span id="health-text" class="text-xs text-muted-foreground">CHECKING...</span>
            </div>
          </div>
        </header>

        <!-- Page content -->
        <main id="main-content" class="flex-1 overflow-y-auto p-6">
          <slot />

          <!-- Scroll to top button -->
          <button
            id="scroll-top-btn"
            class="fixed bottom-6 right-6 z-40 hidden h-10 w-10 items-center justify-center rounded-full border border-border bg-lovelace-950/90 text-muted-foreground shadow-lg backdrop-blur-sm transition-all hover:bg-accent hover:text-foreground"
            aria-label="Scroll to top"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="18 15 12 9 6 15" />
            </svg>
          </button>
        </main>
      </div>
    </div>

    <!-- Scroll to top -->
    <script>
      const mainEl = document.getElementById("main-content");
      const scrollBtn = document.getElementById("scroll-top-btn");
      if (mainEl && scrollBtn) {
        mainEl.addEventListener("scroll", () => {
          if (mainEl.scrollTop > 400) {
            scrollBtn.classList.remove("hidden");
            scrollBtn.classList.add("flex");
          } else {
            scrollBtn.classList.add("hidden");
            scrollBtn.classList.remove("flex");
          }
        });
        scrollBtn.addEventListener("click", () => {
          mainEl.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>

    <!-- Health check -->
    <script>
      (function () {
        const dot = document.getElementById("health-dot");
        const ping = document.getElementById("health-ping");
        const text = document.getElementById("health-text");
        if (!dot || !ping || !text) return;

        function setStatus(ok: boolean) {
          const color = ok ? "bg-lv-green" : "bg-lv-red";
          const remove = ok ? "bg-lv-red" : "bg-lv-green";
          dot.classList.remove("bg-muted-foreground", remove);
          dot.classList.add(color);
          ping.classList.remove("bg-muted-foreground", remove);
          ping.classList.add(color);
          text.textContent = ok ? "MONITORING" : "UNHEALTHY";
        }

        async function checkHealth() {
          // Skip health checks when the tab is hidden to avoid wasting
          // bandwidth and triggering 403s from auth proxies.
          if (document.hidden) return;
          try {
            const res = await fetch("/api/health", { cache: "no-store" });
            if (!res.ok) { setStatus(false); return; }
            const data = await res.json();
            setStatus(data.version != null);
            // Also update sidebar version (shared with health check to avoid duplicate fetch).
            const versionEl = document.getElementById("sidebar-version");
            if (versionEl && data.version) {
              const crs = data.crs_version ? ` · CRS ${data.crs_version}` : "";
              versionEl.textContent = `wafctl v${data.version}${crs}`;
            }
          } catch {
            setStatus(false);
          }
        }

        checkHealth();
        setInterval(checkHealth, 30_000);

        // When the user switches back to the tab, run an immediate check
        // so the indicator updates without waiting for the next tick.
        document.addEventListener("visibilitychange", () => {
          if (!document.hidden) checkHealth();
        });
      })();
    </script>

    <!-- Collapsible sidebar sections -->
    <script>
      (function () {
        const STORAGE_KEY = "wafctl-nav-collapsed";
        let collapsed: Set<string>;
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          collapsed = raw ? new Set(JSON.parse(raw)) : new Set();
        } catch {
          collapsed = new Set();
        }

        function persist() {
          try { localStorage.setItem(STORAGE_KEY, JSON.stringify([...collapsed])); } catch {}
        }

        function applyState(section: string) {
          const linksEl = document.querySelector<HTMLElement>(`.nav-section-links[data-section="${section}"]`);
          const chevron = document.querySelector<SVGElement>(`.nav-section[data-section="${section}"] .nav-chevron`);
          if (!linksEl) return;
          if (collapsed.has(section)) {
            linksEl.style.display = "none";
            if (chevron) chevron.style.transform = "rotate(0deg)";
          } else {
            linksEl.style.display = "";
            if (chevron) chevron.style.transform = "rotate(90deg)";
          }
        }

        // Apply initial state — never collapse a section containing the active link
        document.querySelectorAll<HTMLElement>(".nav-section-links").forEach((el) => {
          const section = el.dataset.section!;
          if (el.dataset.hasActive === "true") collapsed.delete(section);
          applyState(section);
        });

        // Attach toggle handlers
        document.querySelectorAll<HTMLButtonElement>(".nav-section-toggle").forEach((btn) => {
          btn.addEventListener("click", () => {
            const section = btn.dataset.section!;
            if (collapsed.has(section)) collapsed.delete(section);
            else collapsed.add(section);
            persist();
            applyState(section);
          });
        });
      })();
    </script>

    <!-- Mobile nav overlay -->
    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const sidebar = document.getElementById("sidebar");
      if (btn && sidebar) {
        btn.addEventListener("click", () => {
          sidebar.classList.toggle("hidden");
          sidebar.classList.toggle("fixed");
          sidebar.classList.toggle("inset-0");
          sidebar.classList.toggle("z-50");
          sidebar.classList.toggle("w-60");
        });
        // Close sidebar when clicking a link on mobile
        sidebar.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            if (sidebar.classList.contains("fixed")) {
              sidebar.classList.add("hidden");
              sidebar.classList.remove("fixed", "inset-0", "z-50");
            }
          });
        });
      }
    </script>
  </body>
</html>
