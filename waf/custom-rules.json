  {
    "id": "943120",
    "name": "Session fixation \u2014 session ID parameter without referer",
    "description": "Detects common session ID parameter names in requests with no Referer header \u2014 suggests an attacker is injecting a session token via a crafted link. CRS 943110/943120.",
    "type": "detect",
    "conditions": [
      {
        "field": "all_args_names",
        "operator": "phrase_match",
        "list_items": [
          "jsessionid",
          "aspsessionid",
          "asp.net_sessionid",
          "phpsessid",
          "phpsessionid",
          "weblogicsession",
          "session_id",
          "sessionid",
          "cfid",
          "cftoken",
          "cfsid",
          "sid",
          "sessid",
          "zenid"
        ],
        "transforms": [
          "lowercase"
        ]
      },
      {
        "field": "referer",
        "operator": "eq",
        "value": ""
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "attack-session-fixation",
      "943xxx"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "921250",
    "name": "Old Cookies V1 usage attempt detected",
