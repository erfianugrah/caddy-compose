[
  {
    "id": "9100003",
    "name": "XXE: DOCTYPE/ENTITY with SYSTEM or PUBLIC",
    "type": "detect",
    "conditions": [
      {
        "field": "body",
        "operator": "regex",
        "value": "(?i:<!(?:DOCTYPE|ENTITY)[^>]*(?:SYSTEM|PUBLIC))"
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "attack-xxe",
      "custom-rules"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "9100006",
    "name": "XXE: Parameter entity declaration",
    "type": "detect",
    "conditions": [
      {
        "field": "body",
        "operator": "regex",
        "value": "(?i:<!ENTITY\\s+%)"
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "attack-xxe",
      "custom-rules"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "9100012",
    "name": "CRLF injection in query string",
    "type": "detect",
    "conditions": [
      {
        "field": "query",
        "operator": "regex",
        "value": "(?:%0[dD]%0[aA]|\\r\\n)"
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "attack-protocol",
      "custom-rules"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "9100013",
    "name": "CRLF injection in request headers",
    "type": "detect",
    "conditions": [
      {
        "field": "all_headers",
        "operator": "regex",
        "value": "(?:%0[dD]%0[aA]|\\r\\n)"
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "attack-protocol",
      "custom-rules"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "9100030",
    "name": "Missing Accept header",
    "type": "detect",
    "conditions": [
      {
        "field": "header",
        "operator": "eq",
        "value": "Accept:"
      }
    ],
    "group_op": "and",
    "severity": "NOTICE",
    "paranoia_level": 1,
    "tags": [
      "heuristic",
      "bot-signal"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "9100032",
    "name": "Scanner UA Block",
    "description": "Block known scanner/attack tool User-Agents. Case-insensitive substring match via Aho-Corasick.",
    "type": "block",
    "conditions": [
      {
        "field": "user_agent",
        "operator": "phrase_match",
        "list_items": [
          "sqlmap",
          "havij",
          "nikto",
          "nuclei",
          "acunetix",
          "nessus",
          "qualys",
          "arachni",
          "whatweb",
          "wapiti",
          "skipfish",
          "gobuster",
          "dirbuster",
          "dirb",
          "ffuf",
          "wfuzz",
          "feroxbuster",
          "nmap",
          "masscan",
          "zgrab",
          "censys",
          "shodan",
          "netcraft",
          "burpsuite",
          "burp",
          "zaproxy",
          "zap",
          "httprobe",
          "subfinder",
          "amass",
          "httpx"
        ]
      }
    ],
    "group_op": "and",
    "tags": [
      "scanner",
      "bot-detection"
    ],
    "enabled": true,
    "priority": 100
  },
  {
    "id": "9100033",
    "name": "Missing or empty User-Agent",
    "type": "detect",
    "conditions": [
      {
        "field": "user_agent",
        "operator": "eq",
        "value": ""
      }
    ],
    "group_op": "and",
    "severity": "WARNING",
    "paranoia_level": 1,
    "tags": [
      "heuristic",
      "bot-signal"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "9100034",
    "name": "Missing Referer on non-API GET",
    "type": "detect",
    "conditions": [
      {
        "field": "method",
        "operator": "eq",
        "value": "GET"
      },
      {
        "field": "referer",
        "operator": "eq",
        "value": ""
      }
    ],
    "group_op": "and",
    "severity": "NOTICE",
    "paranoia_level": 1,
    "tags": [
      "heuristic",
      "bot-signal"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "9100035",
    "name": "Generic UA Anomaly",
    "description": "+5 anomaly for generic HTTP library User-Agents (python-requests, curl/, etc.). Combined with other signals to detect automated tools.",
    "type": "detect",
    "conditions": [
      {
        "field": "user_agent",
        "operator": "phrase_match",
        "list_items": [
          "python-requests",
          "go-http-client",
          "libwww-perl",
          "lwp-trivial",
          "wget",
          "curl/",
          "mechanize",
          "scrapy"
        ]
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "heuristic",
      "bot-signal",
      "generic-ua"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "9100036",
    "name": "HTTP/1.0 Anomaly",
    "description": "+2 anomaly for HTTP/1.0 requests. Modern clients use HTTP/1.1 or HTTP/2.",
    "type": "detect",
    "conditions": [
      {
        "field": "http_version",
        "operator": "eq",
        "value": "HTTP/1.0"
      }
    ],
    "group_op": "and",
    "severity": "NOTICE",
    "paranoia_level": 1,
    "tags": [
      "heuristic",
      "bot-signal",
      "protocol"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "920180",
    "name": "POST request missing Content-Type header",
    "description": "POST requests should include a Content-Type header to describe the body format. CRS 920180.",
    "type": "detect",
    "conditions": [
      {
        "field": "method",
        "operator": "eq",
        "value": "POST"
      },
      {
        "field": "header",
        "operator": "eq",
        "value": "Content-Type:"
      }
    ],
    "group_op": "and",
    "severity": "NOTICE",
    "paranoia_level": 1,
    "tags": [
      "protocol-enforcement",
      "920xxx"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "920220",
    "name": "URL encoding abuse in path",
    "description": "Invalid URL encoding sequences in the request path may indicate evasion attempts. Matches percent sign at end of string, followed by non-hex, or followed by only one hex digit at end. CRS 920220.",
    "type": "detect",
    "conditions": [
      {
        "field": "uri_path",
        "operator": "regex",
        "value": "%(?:$|[^0-9a-fA-F]|[0-9a-fA-F](?:$|[^0-9a-fA-F]))"
      }
    ],
    "group_op": "and",
    "severity": "WARNING",
    "paranoia_level": 1,
    "tags": [
      "protocol-enforcement",
      "920xxx"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "920300",
    "name": "Max number of request arguments exceeded",
    "description": "Requests with an excessive number of parameters may indicate HashDoS or parameter pollution attacks. Default limit: 255. CRS 920300.",
    "type": "detect",
    "conditions": [
      {
        "field": "count:all_args_names",
        "operator": "gt",
        "value": "255"
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "protocol-enforcement",
      "920xxx",
      "policy"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "920311",
    "name": "Argument value too long",
    "description": "Excessively long parameter values may indicate buffer overflow or payload injection. Default limit: 400 characters. CRS 920311.",
    "type": "detect",
    "conditions": [
      {
        "field": "all_args_values",
        "operator": "gt",
        "value": "400",
        "transforms": [
          "length"
        ]
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 2,
    "tags": [
      "protocol-enforcement",
      "920xxx",
      "policy"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "920430",
    "name": "HTTP version not allowed by policy",
    "description": "Restricts HTTP protocol versions. Only HTTP/1.1, HTTP/2, and HTTP/3 are allowed. HTTP/0.9 and HTTP/1.0 are blocked. CRS 920430.",
    "type": "detect",
    "conditions": [
      {
        "field": "http_version",
        "operator": "regex",
        "value": "^HTTP/(?:0\\.9|1\\.0)$"
      }
    ],
    "group_op": "and",
    "severity": "WARNING",
    "paranoia_level": 1,
    "tags": [
      "protocol-enforcement",
      "920xxx",
      "policy"
    ],
    "enabled": true,
    "priority": 400
  },
  {
