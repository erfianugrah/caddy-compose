    "priority": 400
  },
  {
    "id": "921170",
    "name": "HTTP/1.0 Protocol Detected",
    "type": "detect",
    "conditions": [
      {
        "field": "all_args_names",
        "operator": "regex",
        "value": "."
      }
    ],
    "group_op": "and",
    "tags": [
      "application-multi",
      "language-multi",
      "platform-multi",
      "attack-protocol"
    ],
    "enabled": false,
    "priority": 400,
    "category": "REQUEST-921-PROTOCOL-ATTACK",
    "crs_file": "REQUEST-921-PROTOCOL-ATTACK.conf",
    "severity": "NOTICE",
    "paranoia_level": 1
  },
  {
    "id": "930111",
    "name": "Path traversal in URI path (decoded)",
    "description": "Detects decoded directory traversal sequences in the URI path itself. Separate from 930110 which checks argument values. CRS 930110.",
    "type": "detect",
    "conditions": [
      {
        "field": "uri_path",
        "operator": "regex",
        "value": "(?:^|[/;\\\\])\\.{2,3}[/;\\\\]",
        "transforms": [
          "urlDecodeUni",
          "normalizePath",
          "removeNulls"
        ]
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "attack-lfi",
      "930xxx"
    ],
    "enabled": true,
    "priority": 400
  },
  {
    "id": "932100",
    "name": "Unix command injection after shell metacharacter",
    "description": "Detects Unix command names following shell metacharacters (;|&$) in arguments. Replaces 9100010 with broader coverage: all common shell prefixes, not just pipe. Comprehensive command wordlist via phrase_match. CRS 932100/932230/932235/932250/932260 combined.",
    "type": "detect",
    "conditions": [
      {
        "field": "all_args",
        "operator": "regex",
        "value": "(?:[;|&`$({]|\\|\\||&&)\\s*(?:(?:/(?:usr/)?(?:s?bin|local/bin)/)?(?:id|cat|ls|whoami|curl|wget|bash|sh|nc|ncat|python[23]?|perl|ruby|php|node|tee|head|tail|less|more|dd|base64|xxd|rev|env|printenv|uname|hostname|ifconfig|ip|ping|traceroute|nslookup|dig|find|grep|egrep|awk|sed|sort|uniq|wc|chmod|chown|chgrp|mkdir|rmdir|rm|cp|mv|touch|kill|pkill|ps|top|netstat|ss|lsof|mount|umount|chroot|sudo|su|apt|yum|dnf|dpkg|rpm|pip|gem|npm|docker|kubectl|systemctl|service|crontab|at|nmap|socat|openssl|ssh|scp|sftp|rsync|tar|gzip|gunzip|bzip2|xz|unzip|nc\\.openbsd|nc\\.traditional)\\b)"
      }
    ],
    "group_op": "and",
    "severity": "CRITICAL",
    "paranoia_level": 1,
    "tags": [
      "attack-rce",
      "932xxx",
      "platform-unix"
    ],
    "enabled": true,
    "priority": 400
  },
  {
