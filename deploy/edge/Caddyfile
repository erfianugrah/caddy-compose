# =========================================================================
# UNMIGRATED SERVARR SITES - thin HTTPS proxy (2026-07-23 main proxy flip).
# vyos-sg DNAT rule 10 sends public 80/443 to this box; every name below is
# TLS-terminated here and proxied to the servarr caddy (https://10.68.71.2),
# which remains the WAF/auth/routing point until each service migrates.
# header_up Host is REQUIRED (strict_sni_host on both sides). waf_off on
# purpose: servarr's WAF stays the inspection layer during the interim -
# running edge CRS too would double-score every request with a ruleset that
# has none of servarr's per-service exceptions. The edge L4 ddos_mitigator
# listener wrapper still jails volumetric abuse pre-TLS.
# As each service migrates: delete its block here, write a real block above
# (import waf + local upstream), and delete the servarr-side block.
# Skipped: test.lab.erfi.io (lab plane, RFC1918 - no public path).
# =========================================================================
caddy.erfi.io {
	import waf_off
	import tls_config_rfc2136
	encode zstd gzip
	reverse_proxy https://10.68.71.2 {
		import proxy_headers
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		transport http {
			tls_server_name caddy.erfi.io
		}
	}
	import error_pages
	import site_log caddy-api
}

