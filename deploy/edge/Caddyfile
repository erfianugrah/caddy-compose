# deno-edge platform: wildcard + custom domain share one block (and one cert).
# tls_server_name {host} = per-request transport clone (no keepalive pooling
# on this hop) - acceptable for these low-traffic apps during the interim.
*.fn.erfi.io, revista.erfi.io {
	import waf_off
	import tls_config_rfc2136
	reverse_proxy https://10.68.71.2 {
		import proxy_headers
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		transport http {
			tls_server_name {host}
		}
	}
	import site_log deno-edge
}

# wafctl -> Caddy admin API proxy, restricted to the edge-waf bridge subnet.
:2020 {
	log {
		output stderr
		level WARN
	}
	@allowed remote_ip 172.31.98.0/24
	handle @allowed {
		reverse_proxy localhost:2019 {
			header_up Host localhost:2019
		}
	}
	handle {
		respond "Forbidden" 403
	}
}
