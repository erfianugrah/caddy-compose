waf.lab.erfi.io {
	import forward_auth
	import tls_config_rfc2136
	encode zstd gzip
	@waf_hashed path /_astro/*
	header @waf_hashed Cache-Control "public, max-age=31536000, immutable"
	header ?Cache-Control "no-store"
	reverse_proxy 172.31.98.2:8080 {
		import proxy_headers
	}
	import error_pages
	import site_log waf
}

