# Secrets
#
# .env IS committed — it is SOPS-encrypted at rest (recipient =
# composer's age key) and decrypted by composer at deploy time. The
# pre-commit hook blocks any commit where .env is plaintext.
#
# .env.mk holds dev-only operator-side values (COMPOSER_API_KEY) which
# never leave the dev machine — stays gitignored.
.env.mk
*.pem
*.key
*.dec

# Out-of-sync API config dump (contains hardcoded tokens)
config.json

# Go binaries
wafctl/wafctl

# Caddy runtime data
/data/
/config/
/log/

# Authelia runtime data (SQLite DB, notification file, logs)
authelia/db.sqlite3
authelia/notification.txt
authelia/authelia.log

# Authelia users database on the host (contains real password hashes)
# The template in authelia/users_database.yml IS committed (placeholder hash only)

# IPsum blocklist (generated at runtime by wafctl scheduled refresh)
ipsum.txt
ipsum_block.caddy

# SBOM output
.sbom/

# Docker
.dockerignore

# CRS source (downloaded by converter, not committed)
tools/coreruleset/

# Playwright
test/playwright/node_modules/
test/playwright/test-results/
test/playwright/playwright-report/

# OS
.DS_Store
tools/crs-converter/crs-converter
caddy-policy-engine/
