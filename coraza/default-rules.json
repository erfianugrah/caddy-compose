{
  "version": 2,
  "rules": [
    {
      "id": "PE-9100003",
      "name": "XXE: DOCTYPE/ENTITY with SYSTEM or PUBLIC",
      "type": "detect",
      "conditions": [
        {
          "field": "body",
          "operator": "regex",
          "value": "(?i:<!(?:DOCTYPE|ENTITY)[^>]*(?:SYSTEM|PUBLIC))"
        }
      ],
      "group_op": "and",
      "severity": "CRITICAL",
      "paranoia_level": 1,
      "tags": ["attack-xxe", "custom-rules"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100006",
      "name": "XXE: Parameter entity declaration",
      "type": "detect",
      "conditions": [
        {
          "field": "body",
          "operator": "regex",
          "value": "(?i:<!ENTITY\\s+%)"
        }
      ],
      "group_op": "and",
      "severity": "CRITICAL",
      "paranoia_level": 1,
      "tags": ["attack-xxe", "custom-rules"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100010",
      "name": "RCE: Pipe to shell command in arguments",
      "type": "detect",
      "conditions": [
        {
          "field": "all_args",
          "operator": "regex",
          "value": "\\|(?:id|cat|ls|whoami|curl|wget|bash|sh|nc|ncat|python[23]?|perl|ruby|php|node|tee|head|tail|less|more|dd|base64|xxd|rev|env|printenv|uname|hostname|passwd|shadow|ifconfig|ip )"
        }
      ],
      "group_op": "and",
      "severity": "CRITICAL",
      "paranoia_level": 1,
      "tags": ["attack-rce", "custom-rules"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100011",
      "name": "RCE: Backtick command substitution",
      "type": "detect",
      "conditions": [
        {
          "field": "all_args",
          "operator": "regex",
          "value": "`[^`]+`"
        }
      ],
      "group_op": "and",
      "severity": "CRITICAL",
      "paranoia_level": 1,
      "tags": ["attack-rce", "custom-rules"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100012",
      "name": "CRLF injection in query string",
      "type": "detect",
      "conditions": [
        {
          "field": "query",
          "operator": "regex",
          "value": "(?:%0[dD]%0[aA]|\\r\\n)"
        }
      ],
      "group_op": "and",
      "severity": "CRITICAL",
      "paranoia_level": 1,
      "tags": ["attack-protocol", "custom-rules"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100013",
      "name": "CRLF injection in request headers",
      "type": "detect",
      "conditions": [
        {
          "field": "all_headers",
          "operator": "regex",
          "value": "(?:%0[dD]%0[aA]|\\r\\n)"
        }
      ],
      "group_op": "and",
      "severity": "CRITICAL",
      "paranoia_level": 1,
      "tags": ["attack-protocol", "custom-rules"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100030",
      "name": "Missing Accept header",
      "type": "detect",
      "conditions": [
        {
          "field": "header",
          "operator": "eq",
          "value": "Accept:"
        }
      ],
      "group_op": "and",
      "severity": "NOTICE",
      "paranoia_level": 1,
      "tags": ["heuristic", "bot-signal"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100033",
      "name": "Missing or empty User-Agent",
      "type": "detect",
      "conditions": [
        {
          "field": "user_agent",
          "operator": "eq",
          "value": ""
        }
      ],
      "group_op": "and",
      "severity": "WARNING",
      "paranoia_level": 1,
      "tags": ["heuristic", "bot-signal"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100034",
      "name": "Missing Referer on non-API GET",
      "type": "detect",
      "conditions": [
        {
          "field": "method",
          "operator": "eq",
          "value": "GET"
        },
        {
          "field": "referer",
          "operator": "eq",
          "value": ""
        }
      ],
      "group_op": "and",
      "severity": "NOTICE",
      "paranoia_level": 1,
      "tags": ["heuristic", "bot-signal"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100032",
      "name": "Scanner UA Block",
      "description": "Block known scanner/attack tool User-Agents. Case-insensitive substring match via Aho-Corasick.",
      "type": "block",
      "conditions": [
        {
          "field": "user_agent",
          "operator": "phrase_match",
          "list_items": [
            "sqlmap", "havij",
            "nikto", "nuclei", "acunetix", "nessus", "qualys", "arachni", "whatweb", "wapiti", "skipfish",
            "gobuster", "dirbuster", "dirb", "ffuf", "wfuzz", "feroxbuster",
            "nmap", "masscan", "zgrab", "censys", "shodan", "netcraft",
            "burpsuite", "burp", "zaproxy", "zap",
            "httprobe", "subfinder", "amass", "httpx"
          ]
        }
      ],
      "group_op": "and",
      "tags": ["scanner", "bot-detection"],
      "enabled": true,
      "priority": 100
    },
    {
      "id": "PE-9100035",
      "name": "Generic UA Anomaly",
      "description": "+5 anomaly for generic HTTP library User-Agents (python-requests, curl/, etc.). Combined with other signals to detect automated tools.",
      "type": "detect",
      "conditions": [
        {
          "field": "user_agent",
          "operator": "phrase_match",
          "list_items": [
            "python-requests", "go-http-client", "libwww-perl", "lwp-trivial",
            "wget", "curl/", "mechanize", "scrapy"
          ]
        }
      ],
      "group_op": "and",
      "severity": "CRITICAL",
      "paranoia_level": 1,
      "tags": ["heuristic", "bot-signal", "generic-ua"],
      "enabled": true,
      "priority": 400
    },
    {
      "id": "PE-9100036",
      "name": "HTTP/1.0 Anomaly",
      "description": "+2 anomaly for HTTP/1.0 requests. Modern clients use HTTP/1.1 or HTTP/2.",
      "type": "detect",
      "conditions": [
        {
          "field": "http_version",
          "operator": "eq",
          "value": "HTTP/1.0"
        }
      ],
      "group_op": "and",
      "severity": "NOTICE",
      "paranoia_level": 1,
      "tags": ["heuristic", "bot-signal", "protocol"],
      "enabled": true,
      "priority": 400
    }
  ]
}
